{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "JU-Dashboard API",
    "description": "REST API for resource catalogue and date-based bookings.\n\n**Base:** `{{baseUrl}}/api/v1`\n\nSet `baseUrl` to your server (e.g. `http://localhost:5000`). After **Create resource**, update `resource_id` in **Create booking**. After **List bookings**, set `booking_id` for **Delete booking**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "resource_id",
      "value": "1"
    },
    {
      "key": "booking_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root (server up)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Resources",
      "item": [
        {
          "name": "List resources",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Body is JSON array', function () {",
                  "    pm.response.to.be.json;",
                  "    const j = pm.response.json();",
                  "    pm.expect(Array.isArray(j)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/resources"
          },
          "response": []
        },
        {
          "name": "Create resource",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 400', function () {",
                  "    pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    const b = pm.response.json();",
                  "    if (b && b.id != null) {",
                  "        pm.collectionVariables.set('resource_id', String(b.id));",
                  "    }",
                  "    pm.test('Response has id, name, type, capacity', function () {",
                  "        pm.expect(b).to.have.property('id');",
                  "        pm.expect(b).to.have.property('name');",
                  "        pm.expect(b).to.have.property('type');",
                  "        pm.expect(b).to.have.property('capacity');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Seminar Room A\",\n  \"type\": \"Room\",\n  \"capacity\": 24\n}"
            },
            "url": "{{baseUrl}}/api/v1/resources"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Body is JSON array', function () {",
                  "    pm.response.to.be.json;",
                  "    const j = pm.response.json();",
                  "    pm.expect(Array.isArray(j)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/bookings"
          },
          "response": []
        },
        {
          "name": "Create booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 400', function () {",
                  "    pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    const b = pm.response.json();",
                  "    if (b && b.id != null) {",
                  "        pm.collectionVariables.set('booking_id', String(b.id));",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource_id\": {{resource_id}},\n  \"requested_by\": \"Dr. Example\",\n  \"booking_date\": \"2026-04-20\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/bookings"
          },
          "response": []
        },
        {
          "name": "Delete booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204, 400, or 404', function () {",
                  "    pm.expect([204, 400, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/bookings/{{booking_id}}"
          },
          "response": []
        }
      ]
    }
  ]
}
